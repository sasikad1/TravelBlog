<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Image -->
    <ImageView
        android:id="@+id/dialogImage"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_gallery"
        android:background="#F0F0F0"
        android:visibility="gone" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/dialogTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Galle Fort Trip"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="#2E7D32"
            android:gravity="center" />

        <TextView
            android:id="@+id/dialogUser"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Posted by: user@example.com"
            android:textSize="12sp"
            android:textColor="#2196F3"
            android:gravity="center"
            android:visibility="gone" />

        <TextView
            android:id="@+id/dialogDate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="March 15, 2026"
            android:textSize="12sp"
            android:textColor="#999999"
            android:gravity="center"
            android:drawableStart="@android:drawable/ic_menu_today"
            android:drawablePadding="4dp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="16dp"
            android:background="#E0E0E0" />

        <TextView
            android:id="@+id/dialogContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Exploring the historic Dutch fortress in southern Sri Lanka..."
            android:textSize="14sp"
            android:textColor="#333333"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>

</LinearLayout>